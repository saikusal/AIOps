# Copy this file to `.env` and fill in real values where needed.
# Do not commit `.env`.

# Core Django / database
POSTGRES_DB=aiops
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,aiops-web,web
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
SITE_ID=1

# Google OAuth
GOOGLE_CLIENT_ID=PASTE_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=PASTE_GOOGLE_CLIENT_SECRET_HERE

# AiDE / model gateway
AIDE_API_URL=https://aide-sdlc-backend.imagine.tech/api/v1/brownfield/chat
AIDE_API_KEY=
AIDE_API_URL_SECONDARY=https://aide-sdlc-backend.imagine.tech/api/v1/brownfield/chat
AIDE_API_KEY_SECONDARY=
AIDE_TIMEOUT=120
AIDE_RETRIES=3
AIDE_VERIFY_SSL=false
AIDE_DEBUG=false
AIDE_CA_BUNDLE=

# LLM backend toggle (aide|vllm)
LLM_BACKEND=aide
VLLM_API_URL=http://<gpu-private-ip>:8001/v1/chat/completions
VLLM_MODEL_NAME=qwen32b
VLLM_TIMEOUT=120
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.1

# Command execution agent
AGENT_SECRET_TOKEN=replace-with-a-long-random-secret
AGENT_PORT=9999

# Observability / telemetry
METRICS_API_URL=http://prometheus:9090
ELASTICSEARCH_URL=
JAEGER_URL=http://jaeger:16686
OTEL_ENABLED=true
OTEL_SERVICE_NAME=aiops-web
SCHEMA_CACHE_TTL=300
PREDICTION_INTERVAL_SECONDS=300

# MCP transport
MCP_TRANSPORT=inprocess
MCP_BASE_URL=http://127.0.0.1:8000
MCP_INTERNAL_TOKEN=replace-with-an-internal-mcp-token

# Policy engine
AIOPS_POLICY_VERSION=2026-04-20
AIOPS_POLICY_PROTECTED_ENVIRONMENTS=production,prod
AIOPS_POLICY_CRITICAL_SERVICES=db,gateway,frontend,app-orders,app-inventory,app-billing
AIOPS_POLICY_RESTART_COOLDOWN_SECONDS=900
AIOPS_POLICY_EXECUTION_RETRY_LIMIT=3
AIOPS_POLICY_RETRY_WINDOW_SECONDS=3600
AIOPS_POLICY_ALLOW_DB_CHANGES=false
AIOPS_POLICY_ALLOW_PROTECTED_ENV_RESTARTS=false
AIOPS_POLICY_REQUIRE_APPROVAL_FOR_RESTARTS=true
AIOPS_POLICY_REQUIRE_APPROVAL_FOR_UNKNOWN_ACTIONS=true

# Phase 2 execution control / behavior versioning
AIOPS_INTENT_SIGNING_SECRET=replace-with-an-intent-signing-secret
AIOPS_APPROVAL_TOKEN_TTL_SECONDS=900
AIOPS_EXECUTION_MAX_FREQUENCY_PER_SERVICE=5
AIOPS_EXECUTION_FREQUENCY_WINDOW_SECONDS=1800
AIOPS_AGENT_BEHAVIOR_NAME=default
AIOPS_PROMPT_VERSION=prompt-v1
AIOPS_MODEL_VERSION=aide
AIOPS_EVIDENCE_RULES_VERSION=evidence-v1
AIOPS_RANKING_VERSION=ranking-v1
AIOPS_RANKING_SUCCESS_WEIGHT=0.55
AIOPS_RANKING_ENVIRONMENT_WEIGHT=0.15
AIOPS_RANKING_HISTORY_WEIGHT=0.20
AIOPS_RANKING_TTR_WEIGHT=0.05
AIOPS_RANKING_BLAST_RADIUS_WEIGHT=0.05
AIOPS_RANKING_TTR_NORMALIZER=1800
AIOPS_RANKING_BLAST_RADIUS_NORMALIZER=10
AIOPS_RANKING_SAMPLE_NORMALIZER=5
AIOPS_REPLAY_CORRECTNESS_WEIGHT=0.30
AIOPS_REPLAY_SAFETY_WEIGHT=0.25
AIOPS_REPLAY_CONSISTENCY_WEIGHT=0.15
AIOPS_REPLAY_RESOLUTION_WEIGHT=0.20
AIOPS_REPLAY_RESTART_AVOIDANCE_WEIGHT=0.10

# Frontend / demo ports
AIOPS_FRONTEND_PORT=8089
DEMO_FRONTEND_PORT=8088

# Demo tuning
DEMO_DB_MAX_CONNECTIONS=40
DEMO_DB_LOG_MIN_DURATION_MS=500
ORDERS_DEFAULT_DB_SLEEP=0
INVENTORY_DEFAULT_DB_SLEEP=0
BILLING_DEFAULT_DB_SLEEP=0

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional app behavior
CORS_ALLOW_ALL_ORIGINS=true
GENAI_TABLE=

SSO_ENABLED=false
AIOPS_PUBLIC_BASE_URL=http://52.62.253.88:8000
AIOPS_PUBLIC_OTLP_GRPC_ENDPOINT=52.62.253.88:4317
DJANGO_CSRF_TRUSTED_ORIGINS=http://52.62.253.88:8000,http://52.62.253.88:8089,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8089,http://127.0.0.1:8089
