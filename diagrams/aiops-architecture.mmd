flowchart LR
    user[User / Operator]
    oauth[Google OAuth]

    subgraph ui[Experience Plane]
        react[React Product UI]
        django_ui[Django Template UI]
    end

    subgraph control[AIOps Control Plane]
        web[Django Web App<br/>genai + doc_search]
        pg[(PostgreSQL)]
        redis[(Redis)]
        vllm[Self-Hosted vLLM<br/>Qwen Local Model]
        agents[control-agent / db-agent]
        codectx[Code Context Engine]
    end

    subgraph repos[Local Source Plane]
        repo[(Local Repositories)]
        gitmeta[Recent Git Changes]
        bindings[Routes / Spans / Symbols]
    end

    subgraph app[Application Plane]
        frontend[Frontend Nginx]
        gateway[Gateway Nginx]
        orders[app-orders]
        inventory[app-inventory]
        billing[app-billing]
        toxiproxy[Toxiproxy]
        db[(Demo Postgres)]
    end

    subgraph obs[Observability Plane]
        prometheus[Prometheus]
        alertmanager[Alertmanager]
        grafana[Grafana]
        otel[OTEL Collector]
        jaeger[Jaeger]
        elastic[Elasticsearch]
        filebeat[Filebeat]
        nodeexp[node-exporter]
        pgexp[postgres-exporter]
        ngxexp[Nginx Exporters]
    end

    user --> react
    user --> django_ui
    react --> web
    django_ui --> web
    oauth --> web

    web --> pg
    web --> redis
    web --> vllm
    web --> agents
